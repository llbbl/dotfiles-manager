# dotfiles-manager — environment overrides (example)
#
# Copy to .env (gitignored) and fill in real values. Loaded automatically
# by `just` (see justfile: `set dotenv-load := true`).

# Remote libSQL/Turso database URL. Overrides [state].url in config.toml.
# Leave unset to use the embedded file default.
# Generate with: turso db show <name> --url
TURSO_DATABASE_URL=

# Long-lived auth token for the remote Turso database.
# Overrides [state].auth_token in config.toml.
# Generate with: turso db tokens create <name>
TURSO_AUTH_TOKEN=

# Audit backend: both (default) | jsonl | db | none
# Non-secret; safe to set in .env directly (no lsm needed).
#DFM_LOG_BACKEND=both

# User-facing log level for the dfm CLI. Sets the threshold for the
# structured dev logger (internal/dlog). Defaults to `error` so a
# default-state invocation is quiet on stderr.
#   DFM_LOG_LEVEL = debug | info | warn | error   (default: error)
# Precedence: --verbose flag (debug) > DFM_LOG_LEVEL > default (error).
# Invalid values cause dfm to exit 2 with a clear stderr message.
#DFM_LOG_LEVEL=

# Structured log routing (independent of DFM_LOG_LEVEL):
#   DFM_LOG_DEST   = stderr | stdout | file:/absolute/path  (default: stderr)
#   DFM_LOG_FORMAT = text | json                            (default: text)
#DFM_LOG_DEST=
#DFM_LOG_FORMAT=
